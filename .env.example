# ENVIRONMENT VARIABLES FOR DEPLOYMENT
# Copy this file and fill in actual values for each deployment environment

# ============================================
# BACKEND - RAILWAY ENVIRONMENT VARIABLES
# ============================================

# API Keys (Get from respective services)
# Groq: https://console.groq.com
# Gemini: https://ai.google.dev
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Database Connection (Auto-provided by Railway PostgreSQL)
# No need to set these - Railway provides automatically
# DATABASE_URL=postgresql://user:password@host:5432/db
# DB_USERNAME=postgres
# DB_PASSWORD=auto-generated-by-railway

# Server Port
PORT=8080

# CORS Configuration (Vercel Frontend URL)
CORS_ALLOWED_ORIGINS=https://your-vercel-frontend.vercel.app,http://localhost:3000

# Spring Environment
SPRING_PROFILES_ACTIVE=production

# ============================================
# FRONTEND - VERCEL ENVIRONMENT VARIABLES
# ============================================

# Backend API URL (From Railway deployment)
# Update with your actual Railway backend URL after deployment
REACT_APP_API_URL=https://your-railway-backend.railway.app

# ============================================
# HOW TO GET THESE KEYS:
# ============================================

# GROQ_API_KEY:
# 1. Go to https://console.groq.com
# 2. Sign up for free account
# 3. Create API key in dashboard
# 4. Copy and paste here

# GEMINI_API_KEY:
# 1. Go to https://ai.google.dev
# 2. Get API key from Google AI Studio
# 3. Copy and paste here

# DATABASE:
# Railway Auto-Setup:
#   - Database is automatically created when deploying to Railway
#   - Credentials are auto-provided via environment variables
#   - No manual configuration needed!

# ============================================
# IMPORTANT SECURITY NOTES:
# ============================================
# 1. NEVER commit this file with real values to GitHub
# 2. Use platform-specific secret management:
#    - Railway: Variables tab in service dashboard
#    - Vercel: Settings → Environment Variables
# 3. Rotate API keys regularly
# 4. Keep API keys secure and private
