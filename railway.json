{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "builder": "railpack",
      "buildCommand": "cd backend && mvn clean package -DskipTests",
      "startCommand": "cd backend && java -Dspring.profiles.active=production -Dserver.port=$PORT -jar target/backend-*.jar",
      "healthcheckPath": "/api/health",
      "envVars": {
        "SPRING_PROFILES_ACTIVE": "production",
        "PORT": "8080",
        "JAVA_OPTS": "-Xmx512m -Xms256m"
      }
    },
    "database": {
      "name": "PostgreSQL",
      "type": "postgres",
      "plan": "free"
    }
  },
  "environment": {
    "GROQ_API_KEY": {
      "description": "Groq API Key for AI question generation",
      "isSecret": true
    },
    "GEMINI_API_KEY": {
      "description": "Google Gemini API Key",
      "isSecret": true
    },
    "CORS_ALLOWED_ORIGINS": {
      "description": "Comma-separated list of allowed origins for CORS",
      "default": "http://localhost:3000"
    },
    "DATABASE_URL": {
      "description": "PostgreSQL connection string (auto-set by Railway)",
      "isSecret": true
    },
    "DB_USERNAME": {
      "description": "Database username (auto-set by Railway)",
      "isSecret": true
    },
    "DB_PASSWORD": {
      "description": "Database password (auto-set by Railway)",
      "isSecret": true
    }
  }
}
