{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "builder": "railpack",
      "buildCommand": "cd backend && mvn clean package -DskipTests",
      "startCommand": "cd backend && java -Dserver.port=$PORT -jar target/backend-*.jar",
      "healthcheckPath": "/api/health",
      "domains": {
        "web": "https://ai-coding-backend-prod.railway.app"
      },
      "envVars": {
        "SPRING_PROFILES_ACTIVE": "production",
        "PORT": "8080"
      }
    },
    "database": {
      "name": "PostgreSQL",
      "type": "postgres",
      "plan": "free"
    }
  },
  "environment": {
    "GROQ_API_KEY": {
      "description": "Groq API Key for AI question generation",
      "isSecret": true
    },
    "GEMINI_API_KEY": {
      "description": "Google Gemini API Key",
      "isSecret": true
    },
    "CORS_ALLOWED_ORIGINS": {
      "description": "Comma-separated list of allowed origins",
      "default": "http://localhost:3000"
    }
  }
}
